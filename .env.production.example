NODE_ENV=production
TZ=Asia/Shanghai
APP_PORT=3000

# Must be replaced in production.
AUTH_SECRET=replace-with-a-long-random-secret
# Trust x-real-ip / x-forwarded-for / cf-connecting-ip only when traffic is behind your trusted reverse proxy.
# Keep false when the app is directly exposed to the internet.
TRUST_PROXY_HEADERS=false

# APK/mobile builds should point client API calls at the deployed HTTPS backend.
NEXT_PUBLIC_API_BASE_URL=https://your-domain.example
# Optional APK landing page metadata.
# If unset, /apk will look for public/downloads/zhihuo-latest.apk
NEXT_PUBLIC_APK_DOWNLOAD_URL=
NEXT_PUBLIC_APK_VERSION=
NEXT_PUBLIC_APK_UPDATED_AT=
NEXT_PUBLIC_APK_SIZE=
# Allow the Capacitor app origin to call the deployed API with cookies.
APP_CORS_ORIGINS=https://localhost,capacitor://localhost

# Postgres connection used by the app.
DATABASE_URL=postgres://zhihuo:zhihuo_change_me@postgres:5432/zhihuo

# Optional DB retry behavior.
DB_RETRY_ATTEMPTS=3

# SMTP config for email verification.
# QQ/foxmail common config:
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=your_email@example.com

# Postgres service variables for docker-compose.
POSTGRES_DB=zhihuo
POSTGRES_USER=zhihuo
POSTGRES_PASSWORD=zhihuo_change_me
POSTGRES_PORT=5432
