NODE_ENV=production
TZ=Asia/Shanghai
APP_PORT=3000

# Must be replaced in production.
AUTH_SECRET=replace-with-a-long-random-secret

# Postgres connection used by the app.
DATABASE_URL=postgres://zhihuo:zhihuo_change_me@postgres:5432/zhihuo

# Optional DB retry behavior.
DB_RETRY_ATTEMPTS=3

# SMTP config for email verification.
# QQ/foxmail common config:
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=your_email@example.com

# Postgres service variables for docker-compose.
POSTGRES_DB=zhihuo
POSTGRES_USER=zhihuo
POSTGRES_PASSWORD=zhihuo_change_me
POSTGRES_PORT=5432
